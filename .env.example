# Copy to .env and fill in. Keys are read from the environment; never commit a real key.
# The live provider (Split 04+) is Azure OpenAI GPT-5.5. All live calls are opt-in and cost
# money — the engine runs fully offline on the stub without any key (Tier-1 tests never need one).

# --- Live provider: Azure OpenAI (GPT-5.5) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2025-01-01-preview
CHAT_LLM_MODEL=gpt-5.5

# --- Or standard api.openai.com (used when AZURE_OPENAI_ENDPOINT is unset) ---
# OPENAI_API_KEY=

# --- Reference provider from the spec (not called in this build) ---
# ANTHROPIC_API_KEY=
